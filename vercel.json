{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/jobs/:slug",
      "destination": "/crewsheetz-v4.html"
    },
    {
      "source": "/:role([A-Za-z0-9_-]{1,20})/:name([A-Za-z0-9-]{1,80})",
      "destination": "/crewsheetz-v4.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
